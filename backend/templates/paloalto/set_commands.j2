# Palo Alto PAN-OS Set Commands
# Generated by IoT Onboarding Tool
# Firewall Context: {{ vars.firewall_context }}
# Device: {{ vars.device_name }}
# Generated for vsys: {{ vars.vsys }}

# ============================================================
# Address Objects
# ============================================================
{% for rule in rules %}
{% for ip in rule.destination_ips %}
{% if ip %}
set address {{ vars.address_prefix }}-{{ ip | replace('.', '-') }} ip-netmask {{ ip }}/32
{% endif %}
{% endfor %}
{% endfor %}

# ============================================================
# Service Objects
# ============================================================
{% for rule in rules %}
{% for svc in rule.services %}
{% set parts = svc.split('/') %}
set service {{ vars.rule_prefix }}-svc-{{ parts[0] }}-{{ parts[1] }} protocol {{ parts[0] }} port {{ parts[1] }}
{% endfor %}
{% endfor %}

# ============================================================
# Security Policy Rules
# ============================================================
{% for rule in rules %}
# Rule {{ rule.index }}: {{ rule.service_group }}
{% if rule.notes %}
# Notes: {{ rule.notes }}
{% endif %}
set rulebase security rules "{{ rule.name }}" from {{ vars.device_zone }}
set rulebase security rules "{{ rule.name }}" to {{ vars.server_zone }}
set rulebase security rules "{{ rule.name }}" source {{ vars.address_prefix }}-device
{% for ip in rule.destination_ips %}
{% if ip %}
set rulebase security rules "{{ rule.name }}" destination {{ vars.address_prefix }}-{{ ip | replace('.', '-') }}
{% endif %}
{% endfor %}
{% for svc in rule.services %}
{% set parts = svc.split('/') %}
set rulebase security rules "{{ rule.name }}" service {{ vars.rule_prefix }}-svc-{{ parts[0] }}-{{ parts[1] }}
{% endfor %}
set rulebase security rules "{{ rule.name }}" application any
set rulebase security rules "{{ rule.name }}" action allow
set rulebase security rules "{{ rule.name }}" tag {{ vars.tag }}
set rulebase security rules "{{ rule.name }}" log-start yes
set rulebase security rules "{{ rule.name }}" log-end yes

{% endfor %}
