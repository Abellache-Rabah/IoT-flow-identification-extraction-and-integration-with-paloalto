<?xml version="1.0" encoding="UTF-8"?>
<!-- Palo Alto PAN-OS XML API Payload -->
<!-- Generated by IoT Onboarding Tool -->
<!-- Firewall Context: {{ vars.firewall_context }} -->
<!-- Device: {{ vars.device_name }} -->
<config>
  <devices>
    <entry name="localhost.localdomain">
      <vsys>
        <entry name="{{ vars.vsys }}">

          <!-- Address Objects -->
          <address>
            {% for rule in rules %}
            {% for ip in rule.destination_ips %}
            {% if ip %}
            <entry name="{{ vars.address_prefix }}-{{ ip | replace('.', '-') }}">
              <ip-netmask>{{ ip }}/32</ip-netmask>
              <tag>
                <member>{{ vars.tag }}</member>
              </tag>
            </entry>
            {% endif %}
            {% endfor %}
            {% endfor %}
          </address>

          <!-- Service Objects -->
          <service>
            {% for rule in rules %}
            {% for svc in rule.services %}
            {% set parts = svc.split('/') %}
            <entry name="{{ vars.rule_prefix }}-svc-{{ parts[0] }}-{{ parts[1] }}">
              <protocol>
                <{{ parts[0] }}>
                  <port>{{ parts[1] }}</port>
                </{{ parts[0] }}>
              </protocol>
            </entry>
            {% endfor %}
            {% endfor %}
          </service>

          <!-- Security Policy Rules -->
          <rulebase>
            <security>
              <rules>
                {% for rule in rules %}
                <entry name="{{ rule.name }}">
                  <from>
                    <member>{{ vars.device_zone }}</member>
                  </from>
                  <to>
                    <member>{{ vars.server_zone }}</member>
                  </to>
                  <source>
                    <member>{{ vars.address_prefix }}-device</member>
                  </source>
                  <destination>
                    {% for ip in rule.destination_ips %}
                    {% if ip %}
                    <member>{{ vars.address_prefix }}-{{ ip | replace('.', '-') }}</member>
                    {% endif %}
                    {% endfor %}
                  </destination>
                  <service>
                    {% for svc in rule.services %}
                    {% set parts = svc.split('/') %}
                    <member>{{ vars.rule_prefix }}-svc-{{ parts[0] }}-{{ parts[1] }}</member>
                    {% endfor %}
                  </service>
                  <application>
                    <member>any</member>
                  </application>
                  <action>allow</action>
                  <log-start>yes</log-start>
                  <log-end>yes</log-end>
                  <tag>
                    <member>{{ vars.tag }}</member>
                  </tag>
                  {% if rule.notes %}
                  <description>{{ rule.notes }}</description>
                  {% endif %}
                </entry>
                {% endfor %}
              </rules>
            </security>
          </rulebase>

        </entry>
      </vsys>
    </entry>
  </devices>
</config>
